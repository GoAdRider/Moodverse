{
	"name": "Flutter Web PWA",
	"build": {
		"dockerfile": "Dockerfile"
	},

	// Claude Code feature 추가
	"features": {
		"ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
	},

	// 로컬 폴더를 직접 마운트 (Windows 경로 형식)
	"workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
	"workspaceFolder": "/workspace",

	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"extensions": [
				// Flutter & Dart
				"Dart-Code.flutter",
				"Dart-Code.dart-code",
				
				// 웹 개발 기본
				"ms-vscode.vscode-json",
				"ms-vscode.vscode-typescript-next",
				
				// PWA & 웹 개발 도구
				"formulahendry.auto-rename-tag",
				"bradlc.vscode-tailwindcss",
				"esbenp.prettier-vscode",
				"ritwickdey.LiveServer",

				// Git & 협업
				"mhutchie.git-graph",
				"eamodio.gitlens",

				// 유틸리티
				"PKief.material-icon-theme",
				"oderwat.indent-rainbow",
				"christian-kohler.path-intellisense",
				
				// 한국어 지원
				"ms-ceintl.vscode-language-pack-ko"
			]
		}
	},

	// Forward ports for Flutter web development
	"forwardPorts": [
		8080,  // Flutter web default port
		3000,  // Alternative web server port
		4000   // PWA testing port
	],

	// Commands to run after the container is created
	"postCreateCommand": "sudo chown -R vscode:vscode /workspace && flutter doctor",

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	"remoteUser": "vscode"
} 